    "esp_tinyusb": {
      "registry": "espressif/esp_tinyusb",
      "repository": "https://github.com/espressif/esp-usb.git",
      "version": "master",
      "path": "device/esp_tinyusb"
    },
    "littlefs": {
      "registry": "joltwallet/littlefs",
      "version": "1.20.1"
    },
    "wasm": {
      "registry": "espressif/wasm-micro-runtime",
      "version": "2.4.0~1"
