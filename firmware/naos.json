{
  "version": "v0.13.1",
  "target": "esp32s3",
  "overrides": {
    "CONFIG_ESPTOOLPY_FLASHSIZE_4MB": null,
    "CONFIG_ESPTOOLPY_FLASHSIZE_8MB": "y",
    "CONFIG_ESPTOOLPY_FLASHSIZE": "8MB",
    "CONFIG_SPIRAM": "y",
    "CONFIG_SPIRAM_MODE_OCT": "n",
    "CONFIG_SPIRAM_USE_MALLOC": "y",
    "CONFIG_BT_ALLOCATION_FROM_SPIRAM_FIRST": "y",
    "CONFIG_BT_BLE_DYNAMIC_ENV_MEMORY": "y",
    "CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP": "y",
    "CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY": "y",
    "CONFIG_TINYUSB_MSC_ENABLED": "y",
    "CONFIG_TINYUSB_MSC_BUFSIZE": "4096",
    "CONFIG_FATFS_LFN_HEAP": "y",
    "CONFIG_LV_COLOR_DEPTH_16": null,
    "CONFIG_LV_COLOR_DEPTH_1": "y",
    "CONFIG_LV_COLOR_DEPTH": "1",
    "CONFIG_LV_USE_THEME_BASIC": null,
    "CONFIG_LV_USE_THEME_MONO": "y",
    "CONFIG_LV_USE_LOG": "y",
    "CONFIG_LV_LOG_LEVEL_WARN": null,
    "CONFIG_LV_LOG_LEVEL_INFO": "y",
    "CONFIG_LV_LOG_LEVEL": "1",
    "CONFIG_ULP_COPROC_ENABLED": "y",
